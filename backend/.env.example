# activia-trace — Variables de Entorno
# Copiar a .env y completar valores reales.
# NO versionar .env con secretos reales.

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/active_trace

# PostgreSQL de test (usar base separada)
DATABASE_URL_TEST=postgresql+asyncpg://user:password@localhost:5432/active_trace_test

# JWT — SECRET_KEY mínimo 32 caracteres
SECRET_KEY=change-me-to-a-min-32-char-secret-string

# AES-256 — ENCRYPTION_KEY exactamente 32 caracteres
ENCRYPTION_KEY=change-me-32-char-encryption-key!

# Expiración del access token en minutos (default: 15)
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Expiración del refresh token en días (default: 7)
REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate limiting en login (max intentos / ventana en segundos)
RATE_LIMIT_MAX_REQUESTS=5
RATE_LIMIT_WINDOW_SECONDS=60

# Expiración del token de recuperación en minutos (default: 15)
RECOVERY_TOKEN_EXPIRE_MINUTES=15

# OpenTelemetry (opcional)
OTEL_SERVICE_NAME=active-trace
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_TRACES_SAMPLER=parentbased_always_on
